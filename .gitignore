# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# netlify local state
.netlify/

# bot runtime data
/data/

# mini-app build (generated on deploy)
/admin/mini-app/node_modules
/public/admin/mini-app-dist/
/admin/mini-app-dist
.the4-api-url

# typescript
*.tsbuildinfo
next-env.d.ts
